# ─────────────────────────────────────────────
#  Pluct App – Local Development Environment
#  Keep this file OUT of version control (.gitignore)
# ─────────────────────────────────────────────

# Local development environment variables
# This file is automatically loaded when running locally

PORT=8788
ASR_PROVIDER=hf
ASR_MODEL=openai/whisper-large-v2
ASR_FALLBACK_TO_LOCAL=false
TMP_DIR=./tmp
KEEP_TEXT_MAX=10000
NODE_ENV=development
ALLOW_PLACEHOLDER_TRANSCRIPTION=false

# TTTranscribe secrets
TTT_BASE=https://iamromeoly-tttranscribe.hf.space
BASE_URL=https://iamromeoly-tttranscribe.hf.space
TEST_URL=https://vm.tiktok.com/ZMADQVF4e/
API_KEY=<ROTATED_API_KEY>
API_SECRET=<ROTATED_API_SECRET>
# Used by the Pluct Business Engine and its internal token vending system
ENGINE_SHARED_SECRET=<ROTATED_ENGINE_SHARED_SECRET>
ENGINE_ADMIN_KEY=<ROTATED_ENGINE_SHARED_SECRET>

TTT_SHARED_SECRET=<ROTATED_HF_OR_TTT_SECRET>
# JWT Secret for TTTranscribe authentication (same as SHARED_SECRET for compatibility)
JWT_SECRET=<ROTATED_HF_OR_TTT_SECRET>
SHARED_SECRET=<ROTATED_HF_OR_TTT_SECRET>



# ── ASR Provider (Speech-to-Text) ────────────
ASR_PROVIDER=hf
HF_API_KEY=<ROTATED_HF_OR_TTT_SECRET>

TMP_DIR=/tmp/ttt
KEEP_TEXT_MAX=10000

# Test JWT for mobile app flow testing
USER_JWT=<ROTATED_USER_JWT>


# ─────────────────────────────────────────────
#  Pluct App – Local Development Environment
#  Keep this file OUT of version control (.gitignore)
# ─────────────────────────────────────────────

# Cloudflare
CLOUDFLARE_API_TOKEN=<ROTATED_CLOUDFLARE_API_TOKEN>
CF_API_TOKEN=<ROTATED_CF_API_TOKEN>
CF_ACCOUNT_ID=<ROTATED_CF_ACCOUNT_ID>

# App Secrets production
ADMIN_KEY=<ROTATED_ADMIN_KEY>
ENGINE_JWT_SECRET=<ROTATED_ENGINE_JWT_SECRET>

# Optional runtime variables (used by your engine)
D1_DATABASE=pluct-db
KV_NAMESPACE=PLUCT_KV
NODE_ENV=development

# Pluct Business Engine Base URL
PLUCT_BASE_URL=https://pluct-business-engine.romeo-lya2.workers.dev




# Cloudflare
CLOUDFLARE_API_TOKEN=<ROTATED_CLOUDFLARE_API_TOKEN>
CF_API_TOKEN=<ROTATED_CF_API_TOKEN>
CF_ACCOUNT_ID=<ROTATED_CF_ACCOUNT_ID>

# App Secrets
ADMIN_SECRET=<ROTATED_ADMIN_SECRET>
JWT_SECRET=<ROTATED_ENGINE_JWT_SECRET>
WEBHOOK_SECRET=<ROTATED_WEBHOOK_SECRET>

# Optional runtime variables (used by your engine)
D1_DATABASE=pluct-db
KV_NAMESPACE=PLUCT_KV
NODE_ENV=development


# Admin Email and Password
AdminEmail=<ROTATED_ADMIN_EMAIL>
AdminPassword=<ROTATED_ADMIN_PASSWORD>
