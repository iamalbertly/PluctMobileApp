{
  "name": "pluct-mobile-tests",
  "private": true,
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "test:all": "node scripts/nodejs/Pluct-Main-01Orchestrator.js",
    "test:all:full": "node scripts/nodejs/Pluct-Main-01Orchestrator.js --force-full",
    "test:core": "node scripts/nodejs/Pluct-Main-01Orchestrator.js -scope Core",
    "test:ui": "node scripts/nodejs/Pluct-Main-01Orchestrator.js -scope UI",
    "test:transcription": "node scripts/nodejs/test-all-transcription.js",
    "test:ci": "cross-env CI=1 node scripts/nodejs/Pluct-Main-01Orchestrator.js --force-full",
    "test:failed": "node scripts/nodejs/Pluct-Main-01Orchestrator.js",
    "test:ux-fixes": "node scripts/nodejs/Pluct-Test-Focused-01UXFixes.js",
    "test:ux-fixes:dev": "cross-env DEV_MODE=1 node scripts/nodejs/Pluct-Test-Focused-01UXFixes.js",
    "test:ux-reliability": "node scripts/nodejs/Pluct-Test-Focused-04UXReliabilityFixes-01Runner.js",
    "test:ux-reliability:dev": "cross-env DEV_MODE=1 node scripts/nodejs/Pluct-Test-Focused-04UXReliabilityFixes-01Runner.js",
    "test:trust-fixes": "node scripts/nodejs/Pluct-Test-Focused-02TrustFixes-01Runner.js",
    "test:trust-fixes:dev": "cross-env DEV_MODE=1 node scripts/nodejs/Pluct-Test-Focused-02TrustFixes-01Runner.js",
    "test:edge-cases": "node scripts/nodejs/Pluct-Main-01Orchestrator.js --tests Journey-EdgeCase",
    "test:trust-fixes:all": "npm run test:trust-fixes && npm run test:edge-cases",
    "test:clear-history": "node scripts/nodejs/Pluct-Test-History-Manager.js clear",
    "test:history-stats": "node scripts/nodejs/Pluct-Test-History-Manager.js stats",
    "test:history-failed": "node scripts/nodejs/Pluct-Test-History-Manager.js failed",
    "test": "powershell -ExecutionPolicy Bypass -File run_tests.ps1",
    "test:dev": "powershell -ExecutionPolicy Bypass -File run_tests.ps1 -DevMode",
    "test:maestro": "node maestro/Pluct-Maestro-Test-01Runner-01Orchestrator.js",
    "test:maestro:dev": "cross-env DEV_MODE=1 node maestro/Pluct-Maestro-Test-01Runner-01Orchestrator.js",
    "test:maestro:ux": "node maestro/Pluct-Maestro-Test-02Focused-01UXImprovements-01Runner.js",
    "test:maestro:ux:dev": "cross-env DEV_MODE=1 node maestro/Pluct-Maestro-Test-02Focused-01UXImprovements-01Runner.js"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}


